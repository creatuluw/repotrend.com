# GitHub Personal Access Token (for GitHub Actions workflows)
# Create a PAT at: https://github.com/settings/tokens
# Required scopes: repo (full control of private repositories)
PAT=your_github_personal_access_token_here

# Bluesky credentials (for posting to Bluesky)
BSKY_HANDLE=your_bsky_handle.bsky.social
BSY_APP_PASSWORD=your_bsky_app_password
MARKUPGO_API_KEY=your_markupgo_api_key
